# Copy this file to `.env` (or set these as environment variables in your
# Vercel/Netlify project settings).
# Never commit `.env` to git — it's already in .gitignore.

# Mapbox — get a free token at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Supabase — find these in your Supabase project's Settings → API page
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
